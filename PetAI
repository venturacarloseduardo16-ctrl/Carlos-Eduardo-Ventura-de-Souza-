<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="PetAI: Triagem veterinária com IA. Identifique sintomas agora e saiba como agir!">
    <title>PetAI - Atendimento Inteligente</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif; background-color: #f5f7f9; height: 100vh; display: flex; flex-direction: column; }
        
        header { background: #111; color: #fff; padding: 15px; text-align: center; font-size: 1.1rem; font-weight: bold; border-bottom: 3px solid #22c55e; }
        
        #chat-window { flex: 1; overflow-y: auto; padding: 15px; display: flex; flex-direction: column; gap: 10px; background: #fff; }
        .msg { padding: 12px 16px; border-radius: 15px; max-width: 85%; font-size: 15px; line-height: 1.4; }
        .user { align-self: flex-end; background: #5d5dff; color: white; border-bottom-right-radius: 2px; }
        .bot { align-self: flex-start; background: #f0f0f0; color: #333; border-bottom-left-radius: 2px; }
        
        #typing { font-size: 12px; color: #999; margin-left: 5px; display: none; }

        .input-area { padding: 15px; background: white; border-top: 1px solid #eee; display: flex; gap: 10px; }
        input { flex: 1; padding: 12px; border: 1px solid #ddd; border-radius: 10px; outline: none; font-size: 16px; }
        button#send-btn { background: #5d5dff; color: white; border: none; padding: 10px 18px; border-radius: 10px; font-weight: bold; }

        #cta-container { display: none; padding: 15px; background: #fff; }
        .btn-kiwify { background: #22c55e; color: white; border: none; width: 100%; padding: 18px; border-radius: 10px; font-size: 16px; font-weight: 800; cursor: pointer; text-transform: uppercase; box-shadow: 0 4px 10px rgba(34, 197, 94, 0.3); }
    </style>
</head>
<body>

<header>🐾 PETAI: TRIAGEM VETERINÁRIA IA</header>

<div id="chat-window">
    <div class="msg bot">Olá! Sou o assistente PetAI. Descreva os sintomas do seu pet para começarmos a triagem.</div>
    <div id="typing">PetAI está analisando...</div>
</div>

<div id="cta-container">
    <button class="btn-kiwify" onclick="checkout()">✅ VER RESULTADO E O QUE FAZER AGORA</button>
</div>

<div class="input-area">
    <input type="text" id="user-input" placeholder="Ex: Meu gato não quer comer..." onkeypress="if(event.key==='Enter') enviar()">
    <button id="send-btn" onclick="enviar()">Enviar</button>
</div>

<script>
    const chat = document.getElementById('chat-window');
    const typing = document.getElementById('typing');
    const cta = document.getElementById('cta-container');

    function enviar() {
        const input = document.getElementById('user-input');
        const text = input.value.trim();
        if (text === "") return;

        addMsg(text, 'user');
        input.value = "";
        
        typing.style.display = "block";
        chat.scrollTop = chat.scrollHeight;

        setTimeout(() => {
            typing.style.display = "none";
            addMsg("Análise concluída. Os sintomas relatados indicam uma situação que precisa de orientação imediata para evitar complicações.", 'bot');
            
            setTimeout(() => {
                addMsg("Para acessar o protocolo de emergência e o relatório de diagnóstico completo, clique no botão abaixo.", 'bot');
                cta.style.display = "block";
                chat.scrollTop = chat.scrollHeight;
            }, 1000);
        }, 2000);
    }

    function addMsg(text, type) {
        const div = document.createElement('div');
        div.className = `msg ${type}`;
        div.innerText = text;
        chat.appendChild(div);
        chat.scrollTop = chat.scrollHeight;
    }

    function checkout() {
        // COLOQUE SEU LINK DA KIWIFY ENTRE AS ASPAS ABAIXO
        window.location.href = "https://pay.kiwify.com.br/SEU_LINK_DA_KIWIFY_AQUI";
    }
</script>

</body>
</html>
